# Local network IP - works for physical devices on same WiFi (FREE!)
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.4:5161

# For Web browser testing, uncomment this instead:
EXPO_PUBLIC_API_BASE_URL=http://localhost:5161

# For Android Emulator, uncomment this instead:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5161

EXPO_PUBLIC_GOOGLE_MAPS_WEB_KEY=YOUR_GOOGLE_MAPS_WEB_KEY_HERE
